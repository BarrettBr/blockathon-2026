# Application Settings
APP_NAME=EquiPay
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Database
SQLITE_URL=sqlite:///./equipay.db

# XRPL Configuration
XRPL_RPC_URL=https://s.devnet.rippletest.net:51234
XRPL_NETWORK=devnet
XRPL_FAUCET_URL=https://faucet.devnet.rippletest.net

# Token & Wallet Config (Add your secrets here!)
RLUSD_CURRENCY=RLUSD
RLUSD_ISSUER=
RLUSD_ISSUER_SEED=
OPERATOR_WALLET_ADDRESS=
OPERATOR_WALLET_SEED=

# Operational Settings
AUTO_FUND_NEW_WALLETS=true
HANDSHAKE_APPROVAL_DROPS=1
DASHBOARD_RECENT_LIMIT=10
FAUCET_RETRIES=2
XRPL_REQUEST_TIMEOUT_SECONDS=20
