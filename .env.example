# Application Settings
APP_NAME=EquiPay
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Database
SQLITE_URL=sqlite:///./equipay.db

# XRPL Configuration
XRPL_RPC_URL=https://s.devnet.rippletest.net:51234
XRPL_NETWORK=devnet
XRPL_FAUCET_URL=https://faucet.devnet.rippletest.net

# Token & Wallet Config
RLUSD_CURRENCY=RLUSD
RLUSD_ISSUER=
RLUSD_ISSUER_SEED=
OPERATOR_WALLET_ADDRESS=
OPERATOR_WALLET_SEED=

# Vendor Auth + Webhooks
VENDOR_SHARED_SECRET_HEADER=X-Vendor-Secret
WEBHOOK_SIGNATURE_HEADER=X-Equipay-Signature
WEBHOOK_TIMEOUT_SECONDS=10

# Snapshot + AI
PINATA_JWT=
PINATA_UPLOAD_URL=https://api.pinata.cloud/pinning/pinJSONToIPFS
PINATA_GATEWAY_BASE_URL=https://gateway.pinata.cloud/ipfs
PINATA_TIMEOUT_SECONDS=20
SNAPSHOT_DEFAULT_DAYS=30
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Operational Settings
AUTO_FUND_NEW_WALLETS=true
DASHBOARD_RECENT_LIMIT=10
FAUCET_RETRIES=2
XRPL_REQUEST_TIMEOUT_SECONDS=20
